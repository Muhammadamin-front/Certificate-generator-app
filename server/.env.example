# Backend sozlamalari — bu faylni .env ga nusxalang va to'ldiring.
# cp .env.example .env

PORT=3001
TOKEN_TTL=12h

# Admin login (ochiq matn)
ADMIN_LOGIN=ZohidAdmin@123

# Parolning bcrypt hash'i va JWT maxfiy kaliti.
# `npm run hash "AdminZ@123"` buyrug'i orqali yarating va shu yerga joylang.
ADMIN_PASSWORD_HASH=
JWT_SECRET=
